@model AutoSalonGrida.Models.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "Профиль";
}


<div class="row g-4">
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body text-center">
                <img src="@Model.AvatarUrl" alt="Аватар" class="profile-avatar rounded-circle mb-3" />
                <h4 class="mb-1">@Model.FullName</h4>
                <p class="text-muted mb-2">@Model.Email</p>
                <div class="d-flex justify-content-center flex-wrap gap-2">
                    @foreach (var role in Model.Roles)
                    {
                        <span class="badge rounded-pill text-bg-primary">@role</span>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h3 class="mb-3"><i class="fa-solid fa-user-gear"></i> Управление профилем</h3>
                @if (TempData["ProfileMessage"] is string profileMessage)
                {
                    <div class="alert alert-success">@profileMessage</div>
                }
                <form method="post" enctype="multipart/form-data">
                    <input asp-for="AvatarUrl" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="FullName" class="form-label"></label>
                            <input asp-for="FullName" class="form-control" maxlength="25" />
                            <span asp-validation-for="FullName" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control" maxlength="254" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PhoneNumber" class="form-label"></label>
                            <input asp-for="PhoneNumber" class="form-control" maxlength="12" />
                            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="City" class="form-label"></label>
                            <select asp-for="City" class="form-select">
                                <option value="">Выберите город</option>
                                @foreach (var city in AutoSalonGrida.Models.ProfileCities.Russian)
                                {
                                    <option value="@city">@city</option>
                                }
                            </select>
                            <span asp-validation-for="City" class="text-danger"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="About" class="form-label"></label>
                            <textarea asp-for="About" class="form-control" rows="4" maxlength="1000"></textarea>
                            <span asp-validation-for="About" class="text-danger"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="AvatarFile" class="form-label"></label>
                            <input asp-for="AvatarFile" class="form-control" accept=".jpg,.jpeg,.png,.webp" />
                        </div>
                    </div>
                    <button class="btn btn-primary mt-4" type="submit">Сохранить изменения</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
