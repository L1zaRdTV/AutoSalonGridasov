@model AutoSalonGrida.Models.ViewModels.RegisterViewModel
@{ ViewData["Title"] = "Регистрация"; }

<div class="row justify-content-center">
    <div class="col-lg-6 col-md-8">
        <div class="auth-card rounded-4 p-4 p-lg-5">
            <div class="auth-switch">
                <a class="auth-switch-link" asp-action="Login">Вход</a>
                <a class="auth-switch-link active" asp-action="Register">Регистрация</a>
            </div>

            <h1 class="h3 mb-2 center-safe">Создание аккаунта</h1>
            <p class="text-muted center-safe mb-4">Заполните данные, чтобы оформлять покупки и отслеживать заказы.</p>

            <form method="post" novalidate>
                <div asp-validation-summary="ModelOnly" class="alert alert-danger validation-summary-errors"></div>
                <div class="mb-3">
                    <label asp-for="FullName" class="form-label"></label>
                    <input asp-for="FullName" class="form-control" autocomplete="name" maxlength="25" />
                    <span asp-validation-for="FullName" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" type="email" inputmode="email" autocomplete="email" maxlength="254" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="PhoneNumber" class="form-label"></label>
                    <input asp-for="PhoneNumber" class="form-control" type="tel" inputmode="tel" autocomplete="tel" placeholder="+79991234567" pattern="^(\+7|8)\d{10}$" maxlength="12" />
                    <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control" minlength="15" maxlength="20" autocomplete="new-password" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="ConfirmPassword" class="form-label"></label>
                    <input asp-for="ConfirmPassword" class="form-control" minlength="15" maxlength="20" autocomplete="new-password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Role" class="form-label"></label>
                    <select asp-for="Role" class="form-select" id="roleSelect">
                        <option>Пользователь</option>
                        <option>Администратор</option>
                    </select>
                    <span asp-validation-for="Role" class="text-danger"></span>
                </div>
                <div class="mb-4" id="adminPasswordWrap">
                    <label asp-for="AdminPassword" class="form-label"></label>
                    <input asp-for="AdminPassword" class="form-control" autocomplete="new-password" inputmode="numeric" maxlength="4" pattern="^\d{4}$" />
                    <span asp-validation-for="AdminPassword" class="text-danger"></span>
                    <div class="form-text admin-password-text">Код доступа администратора состоит из 4 цифр.</div>
                </div>
                <button class="btn btn-primary w-100" type="submit">Создать аккаунт</button>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const roleSelect = document.getElementById('roleSelect');
        const adminPasswordWrap = document.getElementById('adminPasswordWrap');

        function toggleAdminPassword() {
            adminPasswordWrap.style.display = roleSelect.value === 'Администратор' ? 'block' : 'none';
        }

        roleSelect.addEventListener('change', toggleAdminPassword);
        toggleAdminPassword();
    </script>
}
