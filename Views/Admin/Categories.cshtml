@model IEnumerable<AutoSalonGrida.Models.Category>
@{ ViewData["Title"] = "Категории"; ViewData["AdminTab"] = "Categories"; }

<partial name="_AdminTabs" />

<div class="admin-card rounded-4 p-4">
    @if (TempData["Success"] is string message)
    {
        <div class="alert alert-info">@message</div>
    }
    <h1 class="h3 mb-3">Управление категориями</h1>
    <form method="post" asp-action="AddCategory" class="d-flex gap-2 mb-3">
        <input name="name" class="form-control" placeholder="Введите название категории" />
        <button class="btn btn-primary">Добавить</button>
    </form>
    <ul class="list-group">
    @foreach (var c in Model)
    {
        <li class="list-group-item d-flex justify-content-between align-items-center">
            <span>@c.Name</span>
            <form method="post" asp-action="DeleteCategory" class="mb-0" onsubmit="return confirm('Удалить категорию?');">
                <input type="hidden" name="id" value="@c.Id" />
                <button class="btn btn-sm btn-outline-danger" type="submit">Удалить</button>
            </form>
        </li>
    }
    </ul>
</div>
