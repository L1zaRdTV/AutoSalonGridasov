@model IEnumerable<AutoSalonGrida.Models.Car>
@{
    ViewData["AdminTab"] = "Cars";
    ViewData["Title"] = "Панель администратора";

    string ResolveImage(string? path)
    {
        if (string.IsNullOrWhiteSpace(path) || !path.Contains("/assets/images/", StringComparison.OrdinalIgnoreCase))
            return Url.Content("~/assets/images/default-car.svg");
        return path.StartsWith("~", StringComparison.Ordinal) ? Url.Content(path) : path;
    }
}

@{
    var carCount = Model.Count();
    var categoryCount = Model.Select(c => c.Category?.Name).Where(n => !string.IsNullOrWhiteSpace(n)).Distinct().Count();
    var avgPrice = carCount > 0 ? Model.Average(c => c.Price) : 0;
}

<section class="brands-hero p-4 rounded-4 mb-4">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
        <div>
            <h1 class="mb-2">Панель администратора</h1>
            <p class="text-muted mb-0">Управляйте каталогом, категориями и актуальностью данных в одном месте.</p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a class="btn btn-primary" asp-action="Create"><i class="fa-solid fa-plus me-1"></i>Добавить автомобиль</a>
            <a class="btn btn-outline-primary" asp-action="Categories">Категории</a>
        </div>
    </div>
</section>

<partial name="_AdminTabs" />

<section class="row g-3 mb-4">
    <div class="col-md-4">
        <article class="admin-stat-card rounded-4 p-3 h-100">
            <div class="admin-stat-label">Авто в каталоге</div>
            <div class="admin-stat-value">@carCount</div>
            <p class="text-muted mb-0">Всего доступных карточек автомобилей.</p>
        </article>
    </div>
    <div class="col-md-4">
        <article class="admin-stat-card rounded-4 p-3 h-100">
            <div class="admin-stat-label">Категорий</div>
            <div class="admin-stat-value">@categoryCount</div>
            <p class="text-muted mb-0">Удобная структура для быстрого поиска.</p>
        </article>
    </div>
    <div class="col-md-4">
        <article class="admin-stat-card rounded-4 p-3 h-100">
            <div class="admin-stat-label">Средняя цена</div>
            <div class="admin-stat-value">@avgPrice.ToString("N0") ₽</div>
            <p class="text-muted mb-0">Ориентир по ценам в текущем ассортименте.</p>
        </article>
    </div>
</section>

<div class="admin-card rounded-4 p-3 p-md-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <h2 class="h5 mb-0">Список автомобилей</h2>
        <span class="text-muted small">Используйте действия справа для быстрого редактирования.</span>
    </div>
    <div class="table-responsive">
        <table class="table align-middle mb-0 admin-table">
            <thead>
                <tr>
                    <th>Иллюстрация</th>
                    <th>Автомобиль</th>
                    <th>Категория</th>
                    <th>Цена</th>
                    <th class="text-end">Действия</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var car in Model)
            {
                <tr>
                    <td><img src="@ResolveImage(car.ImageUrl)" width="90" class="rounded" alt="@car.Brand @car.Model"/></td>
                    <td>@car.Brand @car.Model (@car.Year)</td>
                    <td>@car.Category?.Name</td>
                    <td>@car.Price.ToString("N0") ₽</td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@car.Id" class="btn btn-sm btn-outline-primary">Редактировать</a>
                        <a asp-action="Delete" asp-route-id="@car.Id" class="btn btn-sm btn-outline-danger">Удалить</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
