@model AutoSalonGrida.Models.ViewModels.CarFormViewModel
<form method="post" enctype="multipart/form-data" class="admin-card rounded-4 p-4">
    @if (Model.Id.HasValue) { <input asp-for="Id" type="hidden" /> }
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="row g-3">
        <div class="col-md-4"><label asp-for="Brand" class="form-label">Марка</label><input asp-for="Brand" class="form-control" maxlength="60" /><span asp-validation-for="Brand" class="text-danger"></span></div>
        <div class="col-md-4"><label asp-for="Model" class="form-label">Модель</label><input asp-for="Model" class="form-control" maxlength="80" /><span asp-validation-for="Model" class="text-danger"></span></div>
        <div class="col-md-4"><label asp-for="ProductionDate" class="form-label">Дата выпуска</label><input asp-for="ProductionDate" class="form-control" placeholder="00.00.0000" maxlength="10" pattern="^\d{2}\.\d{2}\.\d{4}$" /><span asp-validation-for="ProductionDate" class="text-danger"></span></div>
        <div class="col-md-4"><label asp-for="Price" class="form-label">Цена</label><input asp-for="Price" class="form-control" /></div>
        <div class="col-md-4"><label asp-for="CategoryId" class="form-label">Категория</label><select asp-for="CategoryId" asp-items="Model.CategoryOptions" class="form-select"></select></div>
        <div class="col-md-4"><label asp-for="BodyType" class="form-label">Тип кузова</label><input asp-for="BodyType" class="form-control" maxlength="25" /><span asp-validation-for="BodyType" class="text-danger"></span></div>
        <div class="col-md-6"><label asp-for="EngineType" class="form-label">Двигатель</label><input asp-for="EngineType" class="form-control" maxlength="80" /><span asp-validation-for="EngineType" class="text-danger"></span></div>
        <div class="col-md-6"><label asp-for="Mileage" class="form-label">Пробег</label><input asp-for="Mileage" class="form-control" /></div>
        <div class="col-12"><label asp-for="Description" class="form-label">Описание</label><textarea asp-for="Description" class="form-control" rows="4" maxlength="2500"></textarea><span asp-validation-for="Description" class="text-danger"></span></div>
        <div class="col-md-6"><label asp-for="MainImage" class="form-label">Главная иллюстрация</label><input asp-for="MainImage" class="form-control" type="file" /></div>
        <div class="col-md-6"><label asp-for="GalleryImages" class="form-label">Галерея иллюстраций</label><input asp-for="GalleryImages" class="form-control" type="file" multiple /></div>
    </div>
    <div class="mt-3 d-flex gap-2">
        <button class="btn btn-primary" type="submit">Сохранить</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Отмена</a>
    </div>
</form>
