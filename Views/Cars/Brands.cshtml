@model IEnumerable<string>
@{
    ViewData["Title"] = "Марки";
    var brands = Model.Where(b => !string.IsNullOrWhiteSpace(b)).OrderBy(b => b).ToList();
}

<section class="brands-hero p-4 p-md-5 rounded-4 mb-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 align-items-lg-end">
        <div>
            <h1 class="mb-2 center-safe">Марки автомобилей</h1>
            <p class="mb-0 text-muted center-safe">Откройте каталог по нужной марке и сразу перейдите к подходящим моделям.</p>
        </div>
        <span class="stat-chip"><i class="fa-solid fa-tags"></i> @brands.Count брендов</span>
    </div>
</section>

<section class="row g-3">
    @foreach (var brand in brands)
    {
        <div class="col-6 col-md-4 col-lg-3 col-xl-2">
            <a asp-controller="Cars" asp-action="Index" asp-route-brand="@brand" class="brand-tile rounded-3 p-3 h-100">
                <span>@brand</span>
            </a>
        </div>
    }
</section>
