@model AutoSalonGrida.Models.ViewModels.CarCatalogViewModel
@{
    ViewData["Title"] = "Каталог";

    string ResolveImage(string? path)
    {
        if (string.IsNullOrWhiteSpace(path))
        {
            return Url.Content("~/images/cars/default-car.svg");
        }

        if (path.Contains("/images/cars/", StringComparison.OrdinalIgnoreCase))
        {
            return path.StartsWith("~", StringComparison.Ordinal)
                ? Url.Content(path)
                : (path.StartsWith("/") ? path : Url.Content("~/" + path.TrimStart('/')));
        }

        return Url.Content("~/images/cars/default-car.svg");
    }
}

<section class="catalog-header d-flex align-items-end justify-content-between flex-wrap gap-3 mb-4">
    <div>
        <h1 class="mb-1">Каталог автомобилей</h1>
        <p class="text-muted mb-0">Понятный поиск по ключевым параметрам: быстро и без перегруженности интерфейса.</p>
    </div>
    <span class="stat-chip"><i class="fa-solid fa-car-rear"></i> @Model.Cars.Count авто</span>
</section>

@if (Model.FilterErrors.Any())
{
    <div class="alert alert-danger">
        <ul class="mb-0">
            @foreach (var error in Model.FilterErrors)
            {
                <li>@error</li>
            }
        </ul>
    </div>
}

<form method="get" class="glass-panel catalog-filter-panel rounded-4 p-3 p-lg-4 mb-4 ui-reveal">
    <div class="row g-2 g-lg-3">
        <div class="col-12 col-lg-4">
            <label class="form-label small text-muted mb-1">Поиск</label>
            <input name="search" class="form-control" placeholder="Марка или модель" value="@Model.Search" maxlength="120" />
        </div>
        <div class="col-6 col-lg-2">
            <label class="form-label small text-muted mb-1">Марка</label>
            <select name="brand" asp-items="Model.Brands" class="form-select"><option value="">Все</option></select>
        </div>
        <div class="col-6 col-lg-2">
            <label class="form-label small text-muted mb-1">Кузов</label>
            <select name="bodyType" asp-items="Model.BodyTypes" class="form-select"><option value="">Любой</option></select>
        </div>
        <div class="col-6 col-lg-2">
            <label class="form-label small text-muted mb-1">Цена от</label>
            <input name="minPrice" type="number" class="form-control" placeholder="₽" value="@Model.MinPrice" min="0" step="1" />
        </div>
        <div class="col-6 col-lg-2">
            <label class="form-label small text-muted mb-1">Цена до</label>
            <input name="maxPrice" type="number" class="form-control" placeholder="₽" value="@Model.MaxPrice" min="0" step="1" />
        </div>

        <div class="col-6 col-lg-2">
            <label class="form-label small text-muted mb-1">Дата выпуска от</label>
            <input name="minProductionDate" type="date" class="form-control" value="@Model.MinProductionDate" min="1990-01-01" max="2100-12-31" onkeydown="return false" onpaste="return false" />
        </div>
        <div class="col-6 col-lg-2">
            <label class="form-label small text-muted mb-1">Дата выпуска до</label>
            <input name="maxProductionDate" type="date" class="form-control" value="@Model.MaxProductionDate" min="1990-01-01" max="2100-12-31" onkeydown="return false" onpaste="return false" />
        </div>
        <div class="col-6 col-lg-2">
            <label class="form-label small text-muted mb-1">Пробег до</label>
            <input name="maxMileage" type="number" class="form-control" placeholder="км" value="@Model.MaxMileage" min="0" step="1" />
        </div>
        <div class="col-6 col-lg-2">
            <label class="form-label small text-muted mb-1">Двигатель</label>
            <select name="engineType" asp-items="Model.EngineTypes" class="form-select"><option value="">Любой</option></select>
        </div>
        <div class="col-6 col-lg-2">
            <label class="form-label small text-muted mb-1">Категория</label>
            <select name="categoryId" asp-items="Model.Categories" class="form-select"><option value="">Все</option></select>
        </div>
        <div class="col-6 col-lg-2">
            <label class="form-label small text-muted mb-1">Сортировка</label>
            <select name="sort" class="form-select">
                <option value="">Цена ↑</option>
                <option value="price_desc" selected="@(Model.Sort=="price_desc")">Цена ↓</option>
                <option value="year_asc" selected="@(Model.Sort=="year_asc")">Год ↑</option>
                <option value="year_desc" selected="@(Model.Sort=="year_desc")">Год ↓</option>
            </select>
        </div>
    </div>

    <div class="d-flex flex-wrap gap-2 mt-3">
        <button class="btn btn-primary px-4" type="submit">Показать</button>
        <a class="btn btn-outline-primary" asp-action="Index">Сброс</a>
    </div>
</form>

<div class="row g-4">
    @foreach (var car in Model.Cars)
    {
        var photos = car.Images
            .Select(i => ResolveImage(i.ImagePath))
            .Prepend(ResolveImage(car.ImageUrl))
            .Where(path => !string.IsNullOrWhiteSpace(path))
            .Distinct()
            .Take(6)
            .ToList();
        var carouselId = $"catalog-carousel-{car.Id}";

        <article class="col-12 col-md-6 col-xxl-4">
            <div class="card car-card h-100 border-0 ui-reveal">
                <div id="@carouselId" class="carousel slide car-card-carousel" data-bs-ride="carousel">
                    <div class="carousel-inner">
                        @for (var i = 0; i < photos.Count; i++)
                        {
                            <div class="carousel-item @(i == 0 ? "active" : string.Empty)">
                                <img src="@photos[i]" loading="lazy" class="d-block w-100 car-cover" alt="@car.Brand @car.Model фото @(i + 1)" />
                            </div>
                        }
                    </div>

                    @if (photos.Count > 1)
                    {
                        <button class="carousel-control-prev" type="button" data-bs-target="#@carouselId" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon"></span>
                            <span class="visually-hidden">Предыдущее фото</span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#@carouselId" data-bs-slide="next">
                            <span class="carousel-control-next-icon"></span>
                            <span class="visually-hidden">Следующее фото</span>
                        </button>
                    }
                </div>

                <div class="card-body d-flex flex-column">
                    <h2 class="h5">@car.Brand @car.Model</h2>
                    <p class="text-muted mb-2">@car.Year · @car.Category?.Name</p>
                    <ul class="list-unstyled small text-muted mb-3">
                        <li><i class="fa-solid fa-car-side me-2 text-info"></i>@car.BodyType</li>
                        <li><i class="fa-solid fa-gauge-high me-2 text-info"></i>@car.Mileage.ToString("N0") км</li>
                        <li><i class="fa-solid fa-gas-pump me-2 text-info"></i>@car.EngineType</li>
                    </ul>
                    <p class="fw-semibold text-info fs-5 mb-3">@car.Price.ToString("N0") ₽</p>
                    <div class="d-flex gap-2 mt-auto">
                        <a class="btn btn-outline-primary flex-grow-1" asp-action="Details" asp-route-id="@car.Id">Подробнее</a>
                    </div>
                </div>
            </div>
        </article>
    }
</div>
