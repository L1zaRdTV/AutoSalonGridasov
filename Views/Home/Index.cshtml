@using AutoSalonGrida.Models
@{
    ViewData["Title"] = "Главная";
    var popularCars = ViewBag.PopularCars as List<Car> ?? new();
    var categories = ViewBag.Categories as List<Category> ?? new();

    string ResolveImage(string? path)
    {
        if (string.IsNullOrWhiteSpace(path)) return Url.Content("~/assets/images/default-car.svg");
        return path.Contains("/assets/images/", StringComparison.OrdinalIgnoreCase)
            ? (path.StartsWith("~", StringComparison.Ordinal) ? Url.Content(path) : path)
            : Url.Content("~/assets/images/default-car.svg");
    }
}

<section class="hero-banner hero-banner-enhanced rounded-4 overflow-hidden p-4 p-lg-5 mb-5 ui-reveal">
    <div class="row align-items-center g-4">
        <div class="col-lg-7">
            <span class="stat-chip mb-3"><i class="fa-solid fa-sparkles"></i> Премиальный цифровой автосалон</span>
            <h1 class="display-4 fw-bold display-gradient">Найдите авто мечты за пару минут</h1>
            <p class="lead text-muted">Улучшенный каталог, быстрая навигация по категориям и стабильная работа интерфейса на любых устройствах.</p>
            <div class="d-flex flex-wrap gap-2 mt-4">
                <a class="btn btn-primary btn-lg" asp-controller="Cars" asp-action="Index">Смотреть каталог</a>
                <a class="btn btn-outline-primary btn-lg" asp-controller="Cars" asp-action="Brands">Популярные бренды</a>
            </div>
            <div class="hero-badges mt-4">
                <span><i class="fa-solid fa-shield-heart"></i> Проверенные предложения</span>
                <span><i class="fa-solid fa-bolt"></i> Быстрый отклик</span>
                <span><i class="fa-solid fa-wand-magic-sparkles"></i> Современный дизайн</span>
            </div>
        </div>
        <div class="col-lg-5 text-center">
            <img src="~/assets/images/hero-car.svg" class="img-fluid rounded-4 hero-image" alt="Схематическая иллюстрация автомобиля" />
        </div>
    </div>
</section>

<section class="mb-5 ui-reveal">
    <div class="row g-3">
        <div class="col-md-4">
            <div class="feature-tile p-3 rounded-4 h-100">
                <h3 class="h6 mb-2"><i class="fa-solid fa-filter-circle-dollar me-2"></i>Удобные фильтры</h3>
                <p class="text-muted mb-0">Подбирайте автомобили по бюджету, году выпуска и категории в пару кликов.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="feature-tile p-3 rounded-4 h-100">
                <h3 class="h6 mb-2"><i class="fa-solid fa-images me-2"></i>Наглядные карточки</h3>
                <p class="text-muted mb-0">Слайдеры и подробные фото помогают быстро оценить каждую модель.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="feature-tile p-3 rounded-4 h-100">
                <h3 class="h6 mb-2"><i class="fa-solid fa-cart-shopping me-2"></i>Простой заказ</h3>
                <p class="text-muted mb-0">Добавляйте авто в корзину и оформляйте заказ в едином интерфейсе без лишних шагов.</p>
            </div>
        </div>
    </div>
</section>

<section class="mb-5 ui-reveal">
    <div class="d-flex align-items-center justify-content-between mb-3 gap-2 flex-wrap">
        <h2 class="h3 m-0">Популярные автомобили</h2>
        <span class="text-muted">Подборка актуальных предложений</span>
    </div>
    <div class="row g-4">
        @foreach (var car in popularCars)
        {
            var photos = car.Images.Select(i => ResolveImage(i.ImagePath)).Prepend(ResolveImage(car.ImageUrl)).Distinct().Take(6).ToList();
            var carouselId = $"popular-carousel-{car.Id}";

            <div class="col-sm-6 col-xl-4">
                <div class="card h-100 car-card border-0">
                    <div id="@carouselId" class="carousel slide car-card-carousel" data-bs-ride="carousel">
                        <div class="carousel-inner">
                            @for (var i = 0; i < photos.Count; i++)
                            {
                                <div class="carousel-item @(i == 0 ? "active" : string.Empty)">
                                    <img src="@photos[i]" loading="lazy" class="d-block w-100 car-cover" alt="@car.Brand @car.Model иллюстрация @(i + 1)" />
                                </div>
                            }
                        </div>
                    </div>
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@car.Brand @car.Model</h5>
                        <p class="text-muted mb-1">@car.Year · @car.Category?.Name</p>
                        <p class="fs-5 text-info fw-bold">@car.Price.ToString("N0") ₽</p>
                        <a class="btn btn-outline-primary mt-auto" asp-controller="Cars" asp-action="Details" asp-route-id="@car.Id">Подробнее</a>
                    </div>
                </div>
            </div>
        }
    </div>
</section>

<section class="ui-reveal">
    <h2 class="h3 mb-3 center-safe">Категории автомобилей</h2>
    <div class="row g-3">
        @foreach (var category in categories)
        {
            <div class="col-6 col-md-3">
                <a asp-controller="Cars" asp-action="Index" asp-route-categoryId="@category.Id" class="category-tile rounded-3 p-3">@category.Name</a>
            </div>
        }
    </div>
</section>
